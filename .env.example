# Copia este archivo como .env y completa los valores
# NUNCA subas .env al repositorio (ya está en .gitignore)

# URL del proyecto Supabase (Project URL en Settings → API)
REACT_APP_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clave anónima pública de Supabase (anon/public key en Settings → API)
# Esta clave es segura para el navegador — las políticas RLS protegen los datos
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
