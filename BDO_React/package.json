    "@types/leaflet": "^1.9.17",
    "tailwindcss": "^4.1.4",
    "@tailwindcss/postcss": "^4.1.4",
    "postcss": "^8.5.3",
    "@biomejs/biome": "^1.9.4",
    "prettier": "^3.5.3",
    "husky": "^9.1.7",
