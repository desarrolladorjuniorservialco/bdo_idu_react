    "@tanstack/react-virtual": "^3.13.5",
    "recharts": "^2.15.3",
    "leaflet": "^1.9.4",
    "react-leaflet": "^4.2.1",
    "@react-pdf/renderer": "^4.3.0",
    "class-variance-authority": "^0.7.1",
